# Database
POSTGRES_USER=assistant
POSTGRES_PASSWORD=assistant
POSTGRES_DB=assistant
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Server
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true

# Paths
POLICY_DIR=policy
ARTIFACTS_DIR=artifacts
PROMPTS_DIR=prompts

# Logging
LOG_LEVEL=INFO
DB_ECHO=false

# LLM
API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_ENABLED=true

# Per-agent model overrides (blank = use LLM_MODEL default)
GOAL_EXTRACTOR_MODEL=gpt-5.4
WEB_SCRAPER_MODEL=gpt-5.4
DATA_FORMATTER_MODEL=gpt-5.4-mini
CEO_MODEL=gpt-5.4-mini
CFO_MODEL=gpt-5.4-mini
COVER_LETTER_MODEL=gpt-5.4-mini

# Search
SEARCH_MAX_RESULTS=5
SEARCH_FETCH_TOP_N=3
