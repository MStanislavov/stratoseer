# Database
POSTGRES_USER=assistant
POSTGRES_PASSWORD=assistant
POSTGRES_DB=assistant
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Server
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true

# Paths
POLICY_DIR=policy
ARTIFACTS_DIR=artifacts
PROMPTS_DIR=prompts

# Logging
LOG_LEVEL=INFO
DB_ECHO=false

# LLM (API_KEY is required)
API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3

# Per-agent model overrides (blank = use LLM_MODEL default)
GOAL_EXTRACTOR_MODEL=gpt-5.4
WEB_SCRAPER_MODEL=gpt-5.4
DATA_FORMATTER_MODEL=gpt-5.4-mini
CEO_MODEL=gpt-5.4-mini
CFO_MODEL=gpt-5.4-mini
COVER_LETTER_MODEL=gpt-5.4-mini

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=Stratoseer

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRY_MINUTES=30
JWT_REFRESH_EXPIRY_DAYS=7

# Admin (promoted to admin on startup)
ADMIN_EMAIL=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# App
APP_BASE_URL=http://localhost:8000